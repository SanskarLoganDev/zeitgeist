# Backend .env — local development only
# NEVER commit this file. It is listed in .gitignore.
# On GCP, all these values are injected from Secret Manager at Cloud Run startup.

DJANGO_SETTINGS_MODULE=config.settings.development
DJANGO_SECRET_KEY=replace-with-a-local-dev-secret-key-min-50-chars

# Postgres — matches docker-compose.yml service
DB_NAME=zeitgeist
DB_USER=zeitgeist
DB_PASSWORD=zeitgeist_dev
DB_HOST=localhost
DB_PORT=5432

# Google OAuth — create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=replace-me
GOOGLE_CLIENT_SECRET=replace-me

# Phase 2 — uncomment when needed
NYTIMES_API_KEY=replace-me
RAWG_API_KEY=replace-me
FOOTBALL_DATA_API_KEY=replace-me
# YOUTUBE_API_KEY=replace-me
# TMDB_API_KEY=replace-me
# NASA_API_KEY=replace-me

# Vertex AI / Gemini category summaries
AI_SUMMARIES_ENABLED=false
GOOGLE_CLOUD_PROJECT=replace-me
GOOGLE_CLOUD_LOCATION=global
GOOGLE_GENAI_USE_ENTERPRISE=True
GEMINI_MODEL=gemini-3.5-flash
