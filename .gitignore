# ── GCP / Cloud credentials ───────────────────────────────────────────────────
# Service account key files — should NEVER be committed under any circumstances
*.json                            # Broad catch for accidentally downloaded SA keys
!package.json                     # Exception: Node package manifest IS committed
!package-lock.json                # Exception: lockfile IS committed
!**/fixtures/*.json               # Exception: Django test fixtures ARE committed
# Application Default Credentials
.gcloud/
gcloud-credentials.json
application_default_credentials.json

